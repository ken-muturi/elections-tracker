generator client {
  provider = "prisma-client-js"
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth / Users / Roles
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          String    @id @default(cuid()) @db.VarChar(50)
  title       String    @db.VarChar(50)
  description String    @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  users User[] @relation("userRole")

  @@map("roles")
}

model Account {
  id                 String    @id @default(cuid())
  userId             String    @map("user_id") @db.VarChar(50)
  providerType       String    @map("provider_type")
  providerId         String    @map("provider_id")
  providerAccountId  String    @map("provider_account_id")
  refreshToken       String?   @map("refresh_token")
  accessToken        String?   @map("access_token")
  accessTokenExpires DateTime? @map("access_token_expires")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([providerId, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id") @db.VarChar(50)
  expires      DateTime
  sessionToken String   @unique @map("session_token")
  accessToken  String   @unique @map("access_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model User {
  id                String    @id @default(cuid()) @db.VarChar(50)
  roleId            String    @default("1") @map("role_id") @db.VarChar(50)
  email             String    @unique @db.VarChar(50)
  emailVerified     DateTime? @map("email_verified")
  password          String    @db.VarChar(100)
  image             String?   @db.VarChar(50)
  firstname         String    @db.VarChar(50)
  othernames        String    @db.VarChar(100)
  dateOfBirth       String    @map("date_of_birth") @db.VarChar(20)
  gender            String    @db.VarChar(10)
  nationalId        String    @unique @map("national_id") @db.VarChar(20)
  phone             String    @db.VarChar(20)
  nextOfKin         String    @map("next_of_kin") @db.VarChar(100)
  nextOfKinContacts String    @map("next_of_kin_contacts") @db.VarChar(100)
  address           String?   @db.VarChar(255)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")
  deletedBy         String?   @map("deleted_by") @db.VarChar(50)

  role     Role      @relation("userRole", fields: [roleId], references: [id])
  accounts Account[]
  sessions Session[]

  pollingStationCreator PollingStation[] @relation("pollingStationCreator")
  pollingStationUpdater PollingStation[] @relation("pollingStationUpdater")
  pollingStationDeleter PollingStation[] @relation("pollingStationDeleter")

  // Election system
  electionsCreated Election[]     @relation("electionCreator")
  streamResults    StreamResult[] @relation("streamResultAgent")
  levelResults     LevelResult[]  @relation("levelResultValidator")
  agentAssignments AgentStream[]  @relation("agentStreamUser")

  @@map("users")
}

model VerificationRequest {
  id         String   @id @default(cuid())
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([identifier, token])
  @@map("verification_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// Geographic Hierarchy — PERMANENT (County → Constituency)
//
// Created once by a super-admin, never scoped to an election.
// Constituency boundaries are legally defined and stable.
// ─────────────────────────────────────────────────────────────────────────────

model County {
  id   String @id @default(cuid()) @db.VarChar(50)
  name String @db.VarChar(100)
  code String @unique @db.VarChar(20)

  constituencies Constituency[]

  @@map("counties")
}

model Constituency {
  id       String @id @default(cuid()) @db.VarChar(50)
  countyId String @map("county_id") @db.VarChar(50)
  name     String @db.VarChar(100)
  code     String @unique @db.VarChar(20)

  county County @relation(fields: [countyId], references: [id])
  wards  Ward[]

  @@index([countyId])
  @@map("constituencies")
}

// ─────────────────────────────────────────────────────────────────────────────
// Geographic Hierarchy — NON-PERMANENT (Ward → PollingStation → Stream)
//
// These are configured fresh per election by the admin.
// Ward boundaries can be redrawn; polling stations and streams change with
// each election cycle's registered voter rolls.
//
// Uniqueness is election-scoped:
//   Ward:           (electionId, code)
//   PollingStation: (wardId, code)         — inherits election via ward
//   Stream:         (pollingStationId, code) — inherits election via station
// ─────────────────────────────────────────────────────────────────────────────

model Ward {
  id             String @id @default(cuid()) @db.VarChar(50)
  electionId     String @map("election_id") @db.VarChar(50)
  constituencyId String @map("constituency_id") @db.VarChar(50)
  name           String @db.VarChar(100)
  code           String @db.VarChar(20)

  election        Election         @relation(fields: [electionId], references: [id], onDelete: Cascade)
  constituency    Constituency     @relation(fields: [constituencyId], references: [id])
  pollingStations PollingStation[]

  @@index([constituencyId])
  @@index([electionId])
  @@unique([electionId, code])
  @@map("wards")
}

model PollingStation {
  id               String  @id @default(cuid()) @db.VarChar(50)
  wardId           String  @map("ward_id") @db.VarChar(50)
  name             String  @db.VarChar(200)
  code             String  @db.VarChar(50)
  /// Denormalised for fast filtering without joins
  county           String  @db.VarChar(100)
  constituency     String  @db.VarChar(100)
  ward             String  @db.VarChar(100)
  registeredVoters Int?    @map("registered_voters")

  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String    @map("created_by") @db.VarChar(50)
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedBy String?   @map("updated_by") @db.VarChar(50)
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.VarChar(50)

  creator User  @relation("pollingStationCreator", fields: [createdBy], references: [id])
  updater User? @relation("pollingStationUpdater", fields: [updatedBy], references: [id])
  deleter User? @relation("pollingStationDeleter", fields: [deletedBy], references: [id])

  wardRef Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)
  streams Stream[]

  @@index([wardId])
  @@unique([wardId, code])
  @@map("polling_stations")
}

/// Stream — smallest data-entry unit. One agent enters results per stream.
/// Scoped to an election via PollingStation → Ward → Election.
model Stream {
  id               String  @id @default(cuid()) @db.VarChar(50)
  pollingStationId String  @map("polling_station_id") @db.VarChar(50)
  name             String  @db.VarChar(100)
  code             String  @db.VarChar(20)
  registeredVoters Int?    @map("registered_voters")
  isActive         Boolean @default(true) @map("is_active")

  pollingStation   PollingStation @relation(fields: [pollingStationId], references: [id], onDelete: Cascade)
  streamResults    StreamResult[]
  agentAssignments AgentStream[]

  @@index([pollingStationId, isActive])
  @@unique([pollingStationId, code])
  @@map("streams")
}

// ─────────────────────────────────────────────────────────────────────────────
// Election  (one row per election event)
//
// Positions are fully configurable — admin names them, sets the aggregation
// level, and adds candidates. No fixed enum; server-side validation only.
//
// Well-known position keys for the Kenyan general election:
//   MCA       → WARD
//   MP        → CONSTITUENCY
//   WOMEN_REP → COUNTY
//   SENATOR   → COUNTY
//   GOVERNOR  → COUNTY
//   PRESIDENT → NATIONAL
// These are suggestions only — admin can add any position they need.
// ─────────────────────────────────────────────────────────────────────────────

enum AggregationLevel {
  WARD
  CONSTITUENCY
  COUNTY
  NATIONAL
}

enum ResultStatus {
  DRAFT     // saved but not submitted
  SUBMITTED // agent submitted, awaiting verification
  VERIFIED  // confirmed correct
  DISPUTED  // flagged for dispute
  REJECTED  // rejected, re-entry needed
}

model Election {
  id           String   @id @default(cuid()) @db.VarChar(50)
  title        String   @db.VarChar(200)
  /// e.g. 2026, 2027 — kept separate so queries can filter by year
  year         Int
  electionDate DateTime @map("election_date") @db.Date
  isActive     Boolean  @default(true) @map("is_active")
  description  String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String   @map("created_by") @db.VarChar(50)

  creator          User               @relation("electionCreator", fields: [createdBy], references: [id])
  positions        ElectionPosition[]
  wards            Ward[]
  agentAssignments AgentStream[]

  @@map("elections")
}

/// One row per position contested in this election.
/// type is a free string — admin names it (e.g. "MCA", "Governor", "Village Elder").
/// aggregationLevel drives the actual vote aggregation logic.
model ElectionPosition {
  id               String           @id @default(cuid()) @db.VarChar(50)
  electionId       String           @map("election_id") @db.VarChar(50)
  /// Free-form label, e.g. "MCA", "MP", "Governor", "Village Elder"
  type             String           @db.VarChar(100)
  title            String           @db.VarChar(150)
  aggregationLevel AggregationLevel @map("aggregation_level")
  description      String?          @db.VarChar(300)
  sortOrder        Int              @default(0) @map("sort_order")

  election      Election       @relation(fields: [electionId], references: [id], onDelete: Cascade)
  candidates    Candidate[]
  streamResults StreamResult[]
  levelResults  LevelResult[]

  /// One position type per election (case-insensitive enforced in service layer)
  @@index([electionId])
  @@unique([electionId, type])
  @@map("election_positions")
}

/// A candidate running for a specific position in a specific election.
/// entityId scopes the candidate geographically:
///   aggregationLevel = WARD         → Ward.id
///   aggregationLevel = CONSTITUENCY → Constituency.id
///   aggregationLevel = COUNTY       → County.id
///   aggregationLevel = NATIONAL     → null
model Candidate {
  id         String  @id @default(cuid()) @db.VarChar(50)
  positionId String  @map("position_id") @db.VarChar(50)
  name       String  @db.VarChar(150)
  party      String? @db.VarChar(100)
  photoUrl   String? @map("photo_url") @db.VarChar(500)
  entityId   String? @map("entity_id") @db.VarChar(50)
  sortOrder  Int     @default(0) @map("sort_order")

  position    ElectionPosition      @relation(fields: [positionId], references: [id], onDelete: Cascade)
  streamVotes StreamCandidateVote[]
  levelVotes  LevelCandidateVote[]

  @@index([positionId])
  @@map("candidates")
}

/// Assigns an agent (User) to a stream for data entry.
/// electionId is denormalised here for fast "all assignments for election" queries
/// without traversing Stream → PollingStation → Ward → Election.
model AgentStream {
  id         String  @id @default(cuid()) @db.VarChar(50)
  electionId String  @map("election_id") @db.VarChar(50)
  streamId   String  @map("stream_id") @db.VarChar(50)
  agentId    String  @map("agent_id") @db.VarChar(50)
  isActive   Boolean @default(true) @map("is_active")

  election Election @relation(fields: [electionId], references: [id])
  stream   Stream   @relation(fields: [streamId], references: [id])
  agent    User     @relation("agentStreamUser", fields: [agentId], references: [id])

  @@unique([electionId, streamId, agentId])
  @@map("agent_streams")
}

// ─────────────────────────────────────────────────────────────────────────────
// Stream-level results  (entered by agents at the polling station)
// ─────────────────────────────────────────────────────────────────────────────

model StreamResult {
  id            String       @id @default(cuid()) @db.VarChar(50)
  streamId      String       @map("stream_id") @db.VarChar(50)
  positionId    String       @map("position_id") @db.VarChar(50)
  agentId       String       @map("agent_id") @db.VarChar(50)
  status        ResultStatus @default(DRAFT)
  totalVotes    Int?         @map("total_votes")
  rejectedVotes Int?         @map("rejected_votes")
  notes         String?      @db.Text
  imageUrl      String?      @map("image_url") @db.VarChar(500)
  voiceUrl      String?      @map("voice_url") @db.VarChar(500)
  submittedAt   DateTime     @default(now()) @map("submitted_at")
  updatedAt     DateTime?    @updatedAt @map("updated_at")

  stream   Stream           @relation(fields: [streamId], references: [id])
  position ElectionPosition @relation(fields: [positionId], references: [id])
  agent    User             @relation("streamResultAgent", fields: [agentId], references: [id])
  votes    StreamCandidateVote[]

  @@index([positionId, status])
  @@index([streamId])
  @@unique([streamId, positionId])
  @@map("stream_results")
}

model StreamCandidateVote {
  id             String @id @default(cuid()) @db.VarChar(50)
  streamResultId String @map("stream_result_id") @db.VarChar(50)
  candidateId    String @map("candidate_id") @db.VarChar(50)
  votes          Int    @default(0)

  streamResult StreamResult @relation(fields: [streamResultId], references: [id], onDelete: Cascade)
  candidate    Candidate    @relation(fields: [candidateId], references: [id])

  @@index([streamResultId])
  @@index([candidateId])
  @@unique([streamResultId, candidateId])
  @@map("stream_candidate_votes")
}

// ─────────────────────────────────────────────────────────────────────────────
// Hierarchical level validation
//
// Validators at each level manually confirm the aggregated totals from streams.
//
// entityId is an untyped string pointing to the relevant geographic entity:
//   level = WARD          → Ward.id
//   level = CONSTITUENCY  → Constituency.id
//   level = COUNTY        → County.id
//   level = NATIONAL      → "national" (constant string)
//
// Prisma does not support polymorphic FKs — resolved in application code.
// ─────────────────────────────────────────────────────────────────────────────

model LevelResult {
  id            String           @id @default(cuid()) @db.VarChar(50)
  positionId    String           @map("position_id") @db.VarChar(50)
  level         AggregationLevel
  entityId      String           @map("entity_id") @db.VarChar(50)
  validatorId   String           @map("validator_id") @db.VarChar(50)
  status        ResultStatus     @default(DRAFT)
  totalVotes    Int?             @map("total_votes")
  rejectedVotes Int?             @map("rejected_votes")
  notes         String?          @db.Text
  imageUrl      String?          @map("image_url") @db.VarChar(500)
  voiceUrl      String?          @map("voice_url") @db.VarChar(500)
  submittedAt   DateTime         @default(now()) @map("submitted_at")
  updatedAt     DateTime?        @updatedAt @map("updated_at")

  position  ElectionPosition    @relation(fields: [positionId], references: [id])
  validator User                @relation("levelResultValidator", fields: [validatorId], references: [id])
  votes     LevelCandidateVote[]

  @@index([positionId, status])
  @@unique([positionId, level, entityId])
  @@map("level_results")
}

model LevelCandidateVote {
  id            String @id @default(cuid()) @db.VarChar(50)
  levelResultId String @map("level_result_id") @db.VarChar(50)
  candidateId   String @map("candidate_id") @db.VarChar(50)
  votes         Int    @default(0)

  levelResult LevelResult @relation(fields: [levelResultId], references: [id], onDelete: Cascade)
  candidate   Candidate   @relation(fields: [candidateId], references: [id])

  @@unique([levelResultId, candidateId])
  @@map("level_candidate_votes")
}
